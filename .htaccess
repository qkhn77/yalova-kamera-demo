<IfModule mod_rewrite.c>
RewriteEngine On

# /storage/* isteğini Laravel'e gönder.
# Çünkü document root proje kökü olunca "storage/" dizini fiziksel olarak var ve
# standart !-d !-f kuralları bu istekleri yakalamadan 404'e düşürebiliyor.
RewriteRule ^storage/(.*)$ index.php [L]

# Laravel front controller (redirect YOK)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [L]
</IfModule>

<IfModule mime_module>
AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit