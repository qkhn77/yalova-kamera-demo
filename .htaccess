<IfModule mod_rewrite.c>
RewriteEngine On

# /storage/* isteklerini symlink olmadan storage/app/public/* altına yönlendir.
# document root proje kökü olduğunda admin FileUpload önizlemeleri için gereklidir.
RewriteCond %{REQUEST_URI} !^/storage/app/public/ [NC]
RewriteRule ^storage/(.*)$ storage/app/public/$1 [L]

# Laravel front controller (redirect YOK)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^ index.php [L]
</IfModule>

<IfModule mime_module>
AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>

# php -- BEGIN cPanel-generated handler, do not edit
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php83 .php .php8 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit